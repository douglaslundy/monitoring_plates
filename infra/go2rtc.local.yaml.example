# go2rtc — config LOCAL (NÃO versionado; copie para go2rtc.local.yaml).
#
# OBS: câmeras DUAL-LENS NÃO precisam mais ser definidas aqui. O backend agora as
# registra automaticamente via API, referenciando os templates de recorte
# (`lens_lower` / `lens_upper`) definidos no go2rtc.yaml — fonte sem espaços
# (`ffmpeg:<rtsp>#video=lens_lower`), aceita pela API. Se você tinha um stream
# dual-lens fixado aqui com o UUID da câmera, pode REMOVÊ-LO (o registro via API
# passa a valer e refletir a lente configurada na tela).
#
# Mantenha este arquivo para sobrescritas manuais pontuais, se precisar.

streams: {}
