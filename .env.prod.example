# ── Banco de dados ─────────────────────────────────────────────
POSTGRES_USER=monitoramento
POSTGRES_PASSWORD=TROQUE_SENHA_FORTE_AQUI
POSTGRES_DB=monitoramento
DATABASE_URL=postgresql://monitoramento:TROQUE_SENHA_FORTE_AQUI@postgres:5432/monitoramento

# ── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── JWT ─────────────────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=GERE_UMA_CHAVE_ALEATORIA_DE_64_CARACTERES_AQUI
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Armazenamento de imagens ─────────────────────────────────────
# Usar "s3" para Cloudflare R2 em produção
STORAGE_TYPE=s3
STORAGE_PATH=./storage
S3_BUCKET=monitoramento-frames
S3_ENDPOINT=https://SEU_ACCOUNT_ID.r2.cloudflarestorage.com
S3_ACCESS_KEY=SEU_ACCESS_KEY_ID
S3_SECRET_KEY=SEU_SECRET_ACCESS_KEY

# ── E-mail via Resend ────────────────────────────────────────────
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXX
RESEND_FROM_EMAIL=alertas@seudominio.com

# ── CORS — somente domínio de produção ──────────────────────────
CORS_ORIGINS=https://seudominio.com

# ── Frontend ─────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://seudominio.com

# ── OCR / Agente ─────────────────────────────────────────────────
AGENT_FRAME_INTERVAL=1
AGENT_MIN_CONFIDENCE=0.70
AGENT_DEDUP_SECONDS=30
