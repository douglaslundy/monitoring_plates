# Database
COMPOSE_PROJECT_NAME=monitoramento-git
POSTGRES_USER=monitoramento
POSTGRES_PASSWORD=TROQUE_SENHA_FORTE_AQUI
POSTGRES_DB=monitoramento
DATABASE_URL=postgresql://monitoramento:TROQUE_SENHA_FORTE_AQUI@postgres:5432/monitoramento

# Redis
REDIS_URL=redis://redis:6379

# JWT
SECRET_KEY=GERE_UMA_CHAVE_ALEATORIA_DE_64_CARACTERES_AQUI
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Image storage
STORAGE_TYPE=s3
STORAGE_PATH=./storage
S3_BUCKET=monitoramento-frames
S3_ENDPOINT=https://SEU_ACCOUNT_ID.r2.cloudflarestorage.com
S3_ACCESS_KEY=SEU_ACCESS_KEY_ID
S3_SECRET_KEY=SEU_SECRET_ACCESS_KEY

# Email via Resend
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXX
RESEND_FROM_EMAIL=alertas@seudominio.com

# WhatsApp via Evolution API
WHATSAPP_EVOLUTION_API_KEY=SEU_API_KEY_DA_EVOLUTION_AQUI
WHATSAPP_EVOLUTION_BASE_URL=http://192.168.0.115:8081
WHATSAPP_EVOLUTION_INSTANCE_NAME=whatsapp
WHATSAPP_FRAME_MAX_SIDE=1280
WHATSAPP_FRAME_JPEG_QUALITY=82
WHATSAPP_WEBHOOK_TIMEOUT_SECONDS=20

# CORS
CORS_ORIGINS=https://seudominio.com

# Frontend
NEXT_PUBLIC_API_URL=https://seudominio.com

# OCR / Agent
AGENT_FRAME_INTERVAL=1
AGENT_MIN_CONFIDENCE=0.70
AGENT_DEDUP_SECONDS=30
OCR_WARMUP_ENABLED=1

# Vehicle detection
VEHICLE_CONF_THRESHOLD=0.35
VEHICLE_IOU_THRESHOLD=0.45
VEHICLE_DETECTOR_THREADS=4

# Capture
CAPTURE_FPS=6
MOTION_MIN_AREA_RATIO=0.0035

# Live WebRTC
GO2RTC_ENABLED=true
GO2RTC_URL=http://go2rtc:1984
GO2RTC_PUBLIC_URL=http://192.168.0.115:1984
